{
	"name": "minmat-puskomlekad-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:pull": "drizzle-kit pull",
		"db:seed": "bun run src/lib/server/db/seed",
		"db:seed-superadmin": "bun run src/lib/server/db/seed/superadmin.ts",
		"db:seed-akmil": "bun run src/lib/server/db/seed/akmil.ts",
		"db:seed-puskomlekad": "bun run src/lib/server/db/seed/puskomlekad.ts",
		"db:seed-another-missing-satuan": "bun run src/lib/server/db/seed/another-missing-satuan.ts",
		"db:seed-missing-satuan": "bun run src/lib/server/db/seed/missing-satuan.ts",
		"db:seed-kepala-gudang": "bun run src/lib/server/db/seed/kepala-gudang.ts",
		"db:seed-backfil-equipment": "bun run src/lib/server/db/backfill-equipment-classification.ts",
		"db:seed-operator": "bun run src/lib/server/db/seed/operators.ts",
		"db:seed-units": "bun run src/lib/server/db/seed/units.ts",
		"db:seed-category": "bun run src/lib/server/db/seed/categories.ts",
		"db:clean-mabesad": "bun run src/lib/server/db/scripts/clean-mabesad-inventory.ts",
		"db:seed-test-org": "bun run src/lib/server/db/seed/test-org.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"overrides": {
		"@better-auth/core": "1.5.6"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.2",
