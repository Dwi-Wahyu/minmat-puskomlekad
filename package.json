		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2",
		"yup": "^1.7.1"
	},
	"dependencies": {
		"@better-auth/api-key": "1.5.6",
